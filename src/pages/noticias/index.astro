---
// Archivo: src/pages/noticias/index.astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import {
  Calendar,
  ArrowRight,
  Newspaper,
  Search,
  Sparkles,
  Clock
} from 'lucide-react';

// Obtener noticias y ordenar descendente
const allNoticias = (await getCollection('noticias'))
    .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());

// Separar la noticia destacada (la más reciente) del resto
const featured = allNoticias[0];
const restNoticias = allNoticias.slice(1);
---

<Layout title="Noticias | EP Ingeniería de Sistemas">

  <style>
    /* Animaciones de fondo */
    @keyframes move-blob {
      0% { transform: translate(0px, 0px) scale(1); }
      33% { transform: translate(30px, -50px) scale(1.1); }
      66% { transform: translate(-20px, 20px) scale(0.9); }
      100% { transform: translate(0px, 0px) scale(1); }
    }
    .animate-blob { animation: move-blob 10s infinite alternate; }

    .glass-input {
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.6);
      box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }

    .hero-card-gradient {
      background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 60%, rgba(0,0,0,0.9) 100%);
    }
  </style>

  <section class="relative bg-slate-50 pt-32 pb-16 overflow-hidden">
    <div class="absolute top-[-20%] left-[20%] w-[600px] h-[600px] bg-blue-200/40 rounded-full blur-[100px] animate-blob"></div>
    <div class="absolute top-[10%] right-[-10%] w-[500px] h-[500px] bg-cyan-100/40 rounded-full blur-[100px] animate-blob" style="animation-delay: 2s;"></div>

    <div class="relative z-10 container mx-auto px-6 text-center max-w-4xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 border border-white shadow-sm text-slate-500 text-xs font-bold uppercase tracking-wider mb-8 backdrop-blur-md">
        <Newspaper className="w-4 h-4 text-blue-500" /> Sala de Prensa
      </div>

      <h1 class="text-5xl md:text-7xl font-bold text-slate-900 font-title mb-8 tracking-tight">
        Actualidad <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">Académica</span>
      </h1>

      <p class="text-slate-600 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10 font-light">
        Descubre los logros, investigaciones y eventos que marcan el rumbo de nuestra comunidad universitaria.
      </p>

      <div class="max-w-xl mx-auto relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-400 to-indigo-400 rounded-full opacity-20 group-hover:opacity-40 transition duration-500 blur-lg"></div>
        <div class="relative flex items-center glass-input rounded-full px-6 py-4">
          <Search className="w-5 h-5 text-slate-400 mr-4" />
          <input type="text" placeholder="Buscar noticias, artículos o eventos..." class="w-full bg-transparent border-none outline-none text-slate-700 placeholder:text-slate-400" />
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24 px-6 bg-slate-50 min-h-screen">
    <div class="max-w-7xl mx-auto relative z-10">

      {allNoticias.length > 0 ? (
          <>
            {featured && (
                <div class="mb-16">
                  <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                    <Sparkles className="w-5 h-5 text-amber-500" /> Lo más reciente
                  </h2>

                  <a href={`/noticias/${featured.slug}`} class="group relative block w-full h-[500px] rounded-[2.5rem] overflow-hidden shadow-2xl shadow-blue-900/20">
                    {featured.data.portada ? (
                        <img
                            src={featured.data.portada}
                            alt={featured.data.titulo}
                            class="w-full h-full object-cover transition duration-1000 group-hover:scale-105"
                        />
                    ) : (
                        <div class="w-full h-full bg-slate-200 flex items-center justify-center">Sin Imagen</div>
                    )}

                    <div class="absolute inset-0 hero-card-gradient opacity-90 transition duration-500"></div>

                    <div class="absolute bottom-0 left-0 w-full p-8 md:p-12 flex flex-col items-start">
                            <span class="inline-block px-3 py-1 bg-blue-600 text-white text-[10px] font-bold uppercase tracking-widest rounded-full mb-4 shadow-lg shadow-blue-600/40">
                                Destacado
                            </span>

                      <h3 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight max-w-4xl group-hover:text-blue-200 transition-colors">
                        {featured.data.titulo}
                      </h3>

                      <p class="text-slate-300 text-lg line-clamp-2 max-w-2xl mb-8 font-light">
                        {featured.data.extracto}
                      </p>

                      <div class="flex items-center gap-6 text-sm text-slate-300 font-medium">
                        <div class="flex items-center gap-2">
                          <Calendar className="w-4 h-4 text-blue-400" />
                          {featured.data.fecha.toLocaleDateString('es-PE', { day: 'numeric', month: 'long', year: 'numeric' })}
                        </div>
                        <div class="flex items-center gap-2">
                          <Clock className="w-4 h-4 text-blue-400" />
                          Lectura de 3 min
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
            )}

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
              {restNoticias.map((item) => (
                  <article class="group bg-white rounded-[2rem] shadow-sm hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] hover:-translate-y-2 transition-all duration-300 border border-slate-100 flex flex-col overflow-hidden relative">

                    <div class="h-64 overflow-hidden relative rounded-t-[2rem] m-2 mb-0">
                      {item.data.portada ? (
                          <img
                              src={item.data.portada}
                              alt={item.data.titulo}
                              class="w-full h-full object-cover group-hover:scale-110 transition duration-700 rounded-[1.5rem]"
                          />
                      ) : (
                          <div class="w-full h-full bg-slate-100 flex items-center justify-center text-slate-400 rounded-[1.5rem]">
                            <span class="text-sm">Sin imagen</span>
                          </div>
                      )}

                      <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md text-slate-800 text-xs font-bold px-3 py-1.5 rounded-full shadow-lg flex items-center gap-1.5">
                        {item.data.fecha.toLocaleDateString('es-PE', { day: 'numeric', month: 'short' })}
                      </div>
                    </div>

                    <div class="p-6 md:p-8 flex flex-col flex-grow">
                      <h2 class="text-xl font-bold text-slate-800 mb-3 leading-tight group-hover:text-blue-600 transition-colors line-clamp-2">
                        {item.data.titulo}
                      </h2>
                      <p class="text-slate-500 text-sm mb-6 line-clamp-3 flex-grow leading-relaxed font-light">
                        {item.data.extracto}
                      </p>

                      <div class="pt-6 border-t border-slate-50 mt-auto flex items-center justify-between">
                        <a
                            href={`/noticias/${item.slug}`}
                            class="inline-flex items-center gap-2 text-slate-900 font-bold text-sm hover:text-blue-600 transition-colors group/link"
                        >
                          Leer más
                          <ArrowRight className="w-4 h-4 group-hover/link:translate-x-1 transition-transform" />
                        </a>
                        <span class="text-slate-300">
                                <Newspaper className="w-4 h-4" />
                            </span>
                      </div>
                    </div>
                  </article>
              ))}
            </div>

            {restNoticias.length > 0 && (
                <div class="mt-20 text-center">
                  <button class="px-8 py-3 bg-white border border-slate-200 text-slate-600 font-bold rounded-full hover:bg-slate-50 hover:border-blue-300 hover:text-blue-600 transition-all shadow-sm">
                    Cargar más noticias
                  </button>
                </div>
            )}
          </>
      ) : (
          // ESTADO VACÍO
        <div class="flex flex-col items-center justify-center py-32 text-center bg-white/50 backdrop-blur-sm rounded-[3rem] border border-dashed border-slate-300">
            <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mb-6">
              <Newspaper className="w-10 h-10 text-slate-400" />
            </div>
            <h3 class="text-xl font-bold text-slate-700">No hay noticias publicadas</h3>
            <p class="text-slate-500 mt-2">Vuelve a consultar pronto para novedades.</p>
          </div>
      )}

    </div>
  </section>
</Layout>