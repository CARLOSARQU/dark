---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import {
    History,
    Target,
    Eye,
    Award,
    CheckCircle2,
    Users,
    Lightbulb,
    ArrowRight,
    BrainCircuit,
    ScrollText,
    Sparkles,
} from 'lucide-react';

// Autoridades
const authorities = [
    {
        name: "Dr. Elmer Coyla Idme",
        cargo: "Director de Escuela",
        grado: "Doctor en Ingeniería de Sistemas",
        img: "/img/director-placeholder.webp"
    },
    {
        name: "Mg. Nombre del Secretario",
        cargo: "Secretario Académico",
        grado: "Magíster en TI",
        img: "/img/profesor-placeholder.webp"
    },
    {
        name: "Dra. Nombre Jefe Dpto",
        cargo: "Jefe de Departamento",
        grado: "Doctora en CS",
        img: "/img/profesor2-placeholder.webp"
    }
];

// Competencias
const specificCompetencies = [
    "Diseño de sistemas seguros y escalables bajo estándares globales.",
    "Resolución de problemas complejos con principios de ingeniería y ciencias.",
    "Gestión de seguridad informática y ciberseguridad avanzada.",
    "Data Science y análisis estratégico para la toma de decisiones.",
    "Implementación de Inteligencia Artificial, visión artificial y robótica.",
    "Arquitectura empresarial y gobierno de TI."
];

const academicObjectives = [
    "Aprendizaje de calidad basado en competencias.",
    "Investigación formativa y científica rigurosa.",
    "Integración de la investigación docente en el aula.",
    "Responsabilidad social y ética profesional.",
    "Mejora continua y acreditación internacional."
];
---

<Layout title="Nuestra Escuela | EP Ingeniería de Sistemas">

    <style>
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }
        @keyframes float-slow {
            0% { transform: translate(0px, 0px); }
            50% { transform: translate(10px, -10px); }
            100% { transform: translate(0px, 0px); }
        }
        .animate-float { animation: float 6s ease-in-out infinite; }
        .animate-float-slow { animation: float-slow 8s ease-in-out infinite; }

        .glass-card {
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
        }

        .dark-glass-card {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
        }

        .gradient-text {
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            background-image: linear-gradient(to right, #2563eb, #06b6d4);
        }
    </style>

    <section class="relative bg-slate-50 pt-2 pb-24 overflow-hidden">

        <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-blue-200/40 rounded-full blur-[100px] animate-float-slow"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[500px] h-[500px] bg-cyan-200/30 rounded-full blur-[100px] animate-float"></div>

        <div class="relative z-10 container mx-auto px-6 text-center">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white border border-slate-200 text-slate-500 text-xs font-bold uppercase tracking-wider mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span> Institucional
            </div>

            <h1 class="text-5xl md:text-7xl font-bold text-slate-900 font-title mb-8 tracking-tighter leading-[1.1] max-w-5xl mx-auto">
                Escuela Profesional de <br/>
                <span class="gradient-text">Ingeniería de Sistemas</span>
            </h1>

            <p class="text-lg md:text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-light mb-10">
                Desde 1992, formando líderes tecnológicos que transforman la realidad regional y nacional mediante la innovación, la ética y la excelencia académica.
            </p>

            <div class="flex flex-wrap justify-center gap-4 md:gap-12 py-8 border-y border-slate-200/60 bg-white/30 backdrop-blur-sm max-w-4xl mx-auto rounded-3xl">
                <div class="text-center px-6">
                    <span class="block text-3xl font-bold text-slate-800">+30</span>
                    <span class="text-xs text-slate-500 font-bold uppercase tracking-wider">Años de Historia</span>
                </div>
                <div class="text-center px-6 border-l border-slate-200">
                    <span class="block text-3xl font-bold text-slate-800">Licenciada</span>
                    <span class="text-xs text-slate-500 font-bold uppercase tracking-wider">Por SUNEDU</span>
                </div>
                <div class="text-center px-6 border-l border-slate-200">
                    <span class="block text-3xl font-bold text-slate-800">100%</span>
                    <span class="text-xs text-slate-500 font-bold uppercase tracking-wider">Docentes Graduados</span>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-white relative">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="grid md:grid-cols-2 gap-16 items-center">

                <div class="relative group">
                    <div class="absolute inset-0 bg-blue-600 rounded-[2.5rem] rotate-3 opacity-10 group-hover:rotate-6 transition-transform duration-500"></div>
                    <img src="/img/fachada-epis.webp" alt="Fachada EPIS" class="relative rounded-[2rem] shadow-2xl w-full h-auto object-cover z-10" />

                    <div class="absolute -bottom-6 -right-6 z-20 bg-white p-6 rounded-2xl shadow-xl border border-slate-100 animate-float">
                        <div class="flex items-center gap-3">
                            <div class="bg-blue-100 p-2 rounded-lg text-blue-600">
                                <History className="w-6 h-6" />
                            </div>
                            <div>
                                <p class="text-xs text-slate-500 uppercase font-bold">Fundación</p>
                                <p class="text-xl font-bold text-slate-800">05 Feb 1992</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div>
                    <h2 class="text-4xl font-bold text-slate-900 font-title mb-6 tracking-tight">
                        Un legado de <span class="text-blue-600">innovación</span>
                    </h2>
                    <div class="space-y-6 text-slate-600 text-lg leading-relaxed font-light">
                        <p>
                            Nuestra historia comienza con la <strong>Resolución Rectoral 191-92-R-UNA</strong>. Nacimos en la Facultad de Ingeniería Civil, destacando inmediatamente por el alto nivel académico de nuestros primeros ingresantes.
                        </p>
                        <p>
                            En 2006, consolidamos nuestra identidad integrándonos a la <strong>Facultad de Ingeniería de Sistemas e Informática</strong>, convirtiéndonos en el referente histórico de la tecnología en la universidad.
                        </p>
                        <div class="pt-4 flex flex-wrap gap-4">
                            <a href="/malla-curricular" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition shadow-lg shadow-blue-600/20 hover:-translate-y-0.5">
                                <ScrollText className="w-4 h-4" /> Ver Malla Curricular
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section class="py-24 bg-slate-50 relative overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full max-w-6xl bg-gradient-to-r from-blue-100/50 via-purple-100/50 to-cyan-100/50 blur-3xl opacity-60 rounded-full"></div>

        <div class="container mx-auto px-6 max-w-7xl relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-bold text-slate-900 font-title tracking-tight">Nuestra Razón de Ser</h2>
            </div>

            <div class="grid md:grid-cols-3 gap-8">

                <div class="glass-card p-8 rounded-[2rem] hover:-translate-y-2 transition-transform duration-300 group">
                    <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600 mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                        <Target className="w-7 h-7" />
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-4">Misión</h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        Formar profesionales competitivos en Sistemas y Computación, protagonistas del desarrollo regional y nacional a través de la excelencia académica y la ética.
                    </p>
                </div>

                <div class="glass-card p-8 rounded-[2rem] hover:-translate-y-2 transition-transform duration-300 group">
                    <div class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 mb-6 group-hover:bg-emerald-600 group-hover:text-white transition-colors">
                        <Eye className="w-7 h-7" />
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-4">Visión</h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        Ser reconocidos por egresados que valoran su cultura, participan de manera innovadora y competitiva, contribuyendo activamente al desarrollo sostenible del país.
                    </p>
                </div>

                <div class="glass-card p-8 rounded-[2rem] hover:-translate-y-2 transition-transform duration-300 group">
                    <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600 mb-6 group-hover:bg-amber-600 group-hover:text-white transition-colors">
                        <Lightbulb className="w-7 h-7" />
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-4">Propósito</h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        Soluciones tecnológicas basadas en normas vigentes. Formación integral con excelencia académica, responsabilidad social y promoción de I+D+i.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <section class="py-24 bg-white">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="flex flex-col md:flex-row gap-12">
                <div class="md:w-1/3">
                    <span class="text-blue-600 font-bold tracking-wider uppercase text-sm mb-2 block">Metas Académicas</span>
                    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 leading-tight">Objetivos Estratégicos</h2>
                    <p class="mt-4 text-slate-500">Nuestra hoja de ruta para garantizar la calidad educativa y el éxito profesional.</p>
                </div>

                <div class="md:w-2/3 space-y-4">
                    {academicObjectives.map((obj, i) => (
                            <div class="flex items-start gap-4 p-4 rounded-2xl hover:bg-slate-50 transition border border-transparent hover:border-slate-100 group">
                                <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center font-bold text-xs group-hover:bg-blue-600 group-hover:text-white transition-colors">
                                    {i + 1}
                                </div>
                                <p class="text-slate-700 font-medium pt-1">{obj}</p>
                            </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-[#0B1120] text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-600/20 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-cyan-600/10 rounded-full blur-[120px]"></div>

        <div class="container mx-auto px-6 max-w-7xl relative z-10">
            <div class="text-center mb-16">
                <div class="inline-block p-3 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10 mb-6">
                    <BrainCircuit className="w-8 h-8 text-blue-400" />
                </div>
                <h2 class="text-4xl md:text-5xl font-bold font-title mb-6">Perfil del Egresado</h2>
                <p class="text-slate-400 max-w-2xl mx-auto text-lg">
                    Competencias específicas que te preparan para liderar en la industria tecnológica global.
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {specificCompetencies.map((item, index) => (
                        <div class="dark-glass-card p-6 rounded-2xl hover:bg-white/5 transition duration-300 group">
                            <div class="mb-4 text-blue-400 group-hover:text-blue-300 transition-transform group-hover:scale-110 origin-left">
                                <CheckCircle2 className="w-6 h-6" />
                            </div>
                            <p class="text-slate-300 leading-relaxed font-light text-sm group-hover:text-white transition-colors">
                                {item}
                            </p>
                        </div>
                ))}
            </div>

            <div class="mt-16 text-center">
                <div class="inline-flex flex-wrap justify-center gap-3">
                    {['Pensamiento Crítico', 'Liderazgo', 'Inglés Técnico', 'Ética', 'Innovación'].map(skill => (
                            <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-xs font-bold text-slate-300 uppercase tracking-wider hover:bg-white/10 transition cursor-default">
                            {skill}
                        </span>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <section id="autoridades" class="py-24 bg-slate-50">
        <div class="container mx-auto px-6 max-w-6xl text-center">
            <div class="mb-16">
                <h2 class="text-3xl md:text-5xl font-bold font-title text-slate-900 tracking-tight">Gestión Académica</h2>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                {authorities.map(auth => (
                        <div class="bg-white rounded-[2rem] p-8 shadow-sm border border-slate-100 hover:shadow-2xl hover:shadow-blue-900/5 transition duration-500 group relative overflow-hidden">
                            <div class="absolute top-0 left-0 w-full h-24 bg-gradient-to-b from-slate-50 to-transparent"></div>

                            <div class="relative w-32 h-32 mx-auto mb-6">
                                <div class="absolute inset-0 bg-blue-600 rounded-full blur-xl opacity-20 group-hover:opacity-40 transition"></div>
                                <img src={auth.img} alt={auth.name} class="relative w-full h-full object-cover rounded-full border-4 border-white shadow-lg grayscale group-hover:grayscale-0 transition duration-700" />
                            </div>

                            <h3 class="text-lg font-bold text-slate-900 mb-1">{auth.name}</h3>
                            <p class="text-blue-600 font-bold uppercase text-[10px] tracking-widest mb-3">{auth.cargo}</p>
                            <div class="w-8 h-1 bg-slate-100 mx-auto mb-3 rounded-full"></div>
                            <p class="text-slate-500 text-xs font-medium">{auth.grado}</p>
                        </div>
                ))}
            </div>
        </div>
    </section>



</Layout>