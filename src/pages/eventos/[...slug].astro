---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
    Calendar,
    Clock,
    MapPin,
    ArrowLeft,
    Maximize2,
    ImageOff,
    Share2,
    CalendarDays
} from 'lucide-react';

export const prerender = true;

export async function getStaticPaths() {
    const eventos = await getCollection('eventos');
    return eventos.map(entry => ({
        params: { slug: entry.slug }, props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Formatos de fecha
const dia = entry.data.fechaHora.toLocaleDateString('es-PE', { day: 'numeric', month: 'long' });
const hora = entry.data.fechaHora.toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit' });
const year = entry.data.fechaHora.getFullYear();
const esFuturo = entry.data.fechaHora >= new Date();
---

<Layout title={entry.data.nombre}>

    <style>
        .glass-panel {
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04);
        }

        .glass-bar {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
        }

        /* Animación de fondo */
        @keyframes move-slow {
            0% { transform: translate(0, 0); }
            50% { transform: translate(20px, -20px); }
            100% { transform: translate(0, 0); }
        }
        .animate-blob { animation: move-slow 10s infinite ease-in-out alternate; }
    </style>

    <section class="min-h-screen bg-slate-50 pb-20 pt-2 relative overflow-hidden">

        <div class="fixed top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
            <div class="absolute top-[-10%] right-[-10%] w-[600px] h-[600px] bg-blue-300/20 rounded-full blur-[120px] animate-blob"></div>
            <div class="absolute bottom-[10%] left-[-10%] w-[500px] h-[500px] bg-indigo-300/20 rounded-full blur-[120px] animate-blob" style="animation-delay: -5s;"></div>
        </div>

        <div class="container mx-auto px-6 relative z-10 max-w-6xl">

            <div class="flex items-center justify-between mb-10">
                <a href="/eventos" class="group inline-flex items-center gap-2 text-slate-500 hover:text-blue-600 transition-colors text-sm font-bold bg-white/50 hover:bg-white px-4 py-2 rounded-full backdrop-blur-sm border border-slate-200/50 shadow-sm">
                    <ArrowLeft className="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
                    Volver a Agenda
                </a>

                <button id="share-btn" data-title={entry.data.nombre} class="inline-flex items-center gap-2 text-slate-500 hover:text-blue-600 transition px-4 py-2 rounded-full hover:bg-white/80 border border-transparent hover:border-slate-200 shadow-sm font-bold text-sm" title="Compartir evento">
                    <Share2 className="w-4 h-4" />
                    <span id="share-label">Compartir</span>
                </button>
            </div>

            <div class="grid lg:grid-cols-12 gap-10 items-start">

                <div class="lg:col-span-4 lg:sticky lg:top-32">
                    {entry.data.afiche ? (
                            <div class="relative group rounded-[2rem] overflow-hidden shadow-2xl shadow-blue-900/10 border border-white">
                                <img
                                        src={entry.data.afiche}
                                        alt={`Afiche ${entry.data.nombre}`}
                                        class="w-full h-auto object-cover transition duration-700 group-hover:scale-105"
                                />
                                <div class="absolute inset-0 bg-slate-900/0 group-hover:bg-slate-900/20 transition-colors duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100 cursor-zoom-in">
                                    <div class="bg-white/30 backdrop-blur-md p-4 rounded-full text-white border border-white/40">
                                        <Maximize2 className="w-6 h-6" />
                                    </div>
                                </div>
                            </div>
                    ) : (
                            <div class="w-full aspect-[3/4] bg-slate-100/50 backdrop-blur-sm rounded-[2rem] flex flex-col items-center justify-center text-slate-400 border-2 border-dashed border-slate-200 p-8 text-center">
                                <ImageOff className="w-12 h-12 mb-4 opacity-30" />
                                <span class="text-sm font-medium">Afiche oficial no disponible</span>
                            </div>
                    )}
                </div>

                <div class="lg:col-span-8 flex flex-col gap-6">

                    <div>
                    <span class="inline-block px-3 py-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-[10px] font-bold uppercase tracking-widest rounded-full shadow-lg shadow-blue-500/30 mb-6">
                        {entry.data.tipo}
                    </span>
                        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-title text-slate-900 leading-[1.1] tracking-tight mb-8">
                            {entry.data.nombre}
                        </h1>
                    </div>

                    <div class="glass-bar rounded-2xl p-2 flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x divide-slate-200/50">
                        <div class="flex items-center gap-4 px-6 py-4">
                            <div class="p-2 bg-blue-50 text-blue-600 rounded-lg">
                                <CalendarDays className="w-5 h-5" />
                            </div>
                            <div>
                                <p class="text-xs text-slate-500 font-bold uppercase">Fecha</p>
                                <p class="text-slate-800 font-medium">{dia}, {year}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 px-6 py-4">
                            <div class="p-2 bg-purple-50 text-purple-600 rounded-lg">
                                <Clock className="w-5 h-5" />
                            </div>
                            <div>
                                <p class="text-xs text-slate-500 font-bold uppercase">Hora</p>
                                <p class="text-slate-800 font-medium">{hora}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 px-6 py-4">
                            <div class="p-2 bg-emerald-50 text-emerald-600 rounded-lg">
                                <MapPin className="w-5 h-5" />
                            </div>
                            <div>
                                <p class="text-xs text-slate-500 font-bold uppercase">Lugar</p>
                                <p class="text-slate-800 font-medium">{entry.data.lugar}</p>
                            </div>
                        </div>
                    </div>

                    <div class="glass-panel rounded-[2.5rem] p-8 md:p-12 mt-4 relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 via-purple-400 to-indigo-400"></div>

                        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-3">
                            Detalles del evento
                        </h2>

                        <div class="prose prose-lg prose-slate prose-headings:font-bold prose-headings:text-slate-800 prose-p:text-slate-600 prose-p:leading-relaxed prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-2xl max-w-none">
                            <Content />
                        </div>

                        <div class="mt-12 pt-8 border-t border-slate-200/50">
                            {!esFuturo && (
                                <div class="bg-slate-100 rounded-2xl p-6 border border-slate-200 text-center flex flex-col items-center justify-center gap-3">
                                    <span class="bg-slate-200 p-3 rounded-full text-slate-500">
                                        <Calendar className="w-6 h-6" />
                                    </span>
                                    <div>
                                        <h4 class="font-bold text-slate-700">Evento Finalizado</h4>
                                        <p class="text-sm text-slate-500">Este evento ya se llevó a cabo.</p>
                                    </div>
                                </div>
                            )}
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('share-btn');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const label = document.getElementById('share-label');
      const title = btn.dataset.title || document.title;
      const url = window.location.href;
      try {
        if (navigator.share) {
          await navigator.share({ title, url });
        } else {
          await navigator.clipboard.writeText(url);
          if (label) { label.textContent = '¡Copiado!'; setTimeout(() => { label.textContent = 'Compartir'; }, 2000); }
        }
      } catch {}
    });
  });
</script>
</Layout>