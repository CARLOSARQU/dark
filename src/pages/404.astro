---
import Layout from '../layouts/Layout.astro';
import { ArrowLeft, Home, Search } from 'lucide-react';
---

<Layout
    title="Página no encontrada | EP Ingeniería de Sistemas"
    description="La página que buscas no existe o fue movida."
>
    <style>
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-12px); }
            100% { transform: translateY(0px); }
        }
        .animate-float { animation: float 5s ease-in-out infinite; }
    </style>

    <section class="min-h-[80vh] flex items-center justify-center px-6 relative overflow-hidden bg-slate-50">

        <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-blue-100/40 rounded-full blur-[100px] pointer-events-none"></div>
        <div class="absolute bottom-[-10%] right-[-5%] w-[500px] h-[500px] bg-indigo-100/30 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="relative z-10 text-center max-w-xl mx-auto">

            <div class="animate-float mb-8 inline-block">
                <span class="text-[10rem] font-bold text-transparent bg-clip-text bg-gradient-to-br from-blue-600 to-indigo-400 leading-none select-none">
                    404
                </span>
            </div>

            <h1 class="text-2xl md:text-3xl font-bold text-slate-800 mb-4 font-title">
                Página no encontrada
            </h1>

            <p class="text-slate-500 leading-relaxed mb-10 text-lg font-light">
                La dirección que buscas no existe o fue movida.<br/>
                Verifica el enlace o regresa al inicio.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                    href="/"
                    class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-blue-600 text-white font-bold rounded-2xl hover:bg-blue-700 transition shadow-lg shadow-blue-600/25 hover:-translate-y-0.5"
                >
                    <Home className="w-4 h-4" />
                    Volver al inicio
                </a>

                <button
                    id="open-search-404"
                    class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-white text-slate-700 font-bold rounded-2xl hover:bg-slate-50 transition border border-slate-200 shadow-sm hover:-translate-y-0.5"
                >
                    <Search className="w-4 h-4" />
                    Buscar en el sitio
                </button>
            </div>

            <div class="mt-12 flex flex-wrap justify-center gap-3 text-sm">
                <span class="text-slate-400 font-medium">Páginas principales:</span>
                {[
                    { href: '/escuela', label: 'Escuela' },
                    { href: '/noticias', label: 'Noticias' },
                    { href: '/eventos', label: 'Eventos' },
                    { href: '/docentes', label: 'Docentes' },
                    { href: '/malla-curricular', label: 'Malla Curricular' },
                ].map(link => (
                    <a href={link.href} class="text-blue-600 font-bold hover:underline transition">
                        {link.label}
                    </a>
                ))}
            </div>

        </div>
    </section>

    <script is:inline>
        document.addEventListener('astro:page-load', () => {
            document.getElementById('open-search-404')?.addEventListener('click', () => {
                document.getElementById('search-trigger-desktop')?.click();
            });
        });
    </script>

</Layout>
