---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import {
    Download,
    FileText,
    CalendarDays,
    Award,
    BookOpen,
    ChevronLeft,
    ScrollText,
    ExternalLink,
    Info,
} from 'lucide-react';

const reader = createReader(process.cwd(), keystaticConfig);
const malla = await reader.singletons.mallaCurricular.read();
---

<Layout
    title="Malla Curricular | EP Ingeniería de Sistemas"
    description="Plan de estudios oficial de la Escuela Profesional de Ingeniería de Sistemas - UNAP"
>

    <style>
        @keyframes float-slow {
            0% { transform: translate(0px, 0px); }
            50% { transform: translate(12px, -12px); }
            100% { transform: translate(0px, 0px); }
        }
        .animate-float-slow { animation: float-slow 9s ease-in-out infinite; }

        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
        }
    </style>

    <section class="relative bg-slate-50 pt-2 pb-16 overflow-hidden">
        <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-blue-200/30 rounded-full blur-[100px] animate-float-slow pointer-events-none"></div>
        <div class="absolute bottom-[-5%] left-[-10%] w-[500px] h-[500px] bg-indigo-200/20 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="relative z-10 container mx-auto px-6 max-w-5xl">

            <div class="mb-8">
                <a href="/escuela" class="group inline-flex items-center gap-2 text-slate-500 hover:text-blue-600 font-bold text-sm bg-white/60 hover:bg-white px-5 py-2.5 rounded-full backdrop-blur-md border border-slate-200 shadow-sm transition-all">
                    <ChevronLeft className="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
                    Volver a Nuestra Escuela
                </a>
            </div>

            {malla ? (
                <>
                    {/* ENCABEZADO */}
                    <div class="glass-card rounded-[2.5rem] p-8 md:p-12 mb-8 shadow-xl shadow-blue-900/5">
                        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">

                            <div class="flex-grow">
                                <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-blue-50 text-blue-700 text-xs font-bold uppercase tracking-widest rounded-full mb-5 border border-blue-100">
                                    <ScrollText className="w-3.5 h-3.5" /> Documento Oficial
                                </div>

                                <h1 class="text-3xl md:text-5xl font-bold text-slate-900 font-title tracking-tight leading-tight mb-3">
                                    {malla.planNombre}
                                </h1>
                                <p class="text-slate-500 text-lg font-light">
                                    Escuela Profesional de Ingeniería de Sistemas — UNAP
                                </p>
                            </div>

                            {/* BOTÓN DE DESCARGA */}
                            {malla.archivoPdf ? (
                                <a
                                    href={malla.archivoPdf}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    download
                                    class="group flex-shrink-0 flex flex-col items-center justify-center gap-3 px-8 py-6 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl shadow-xl shadow-blue-600/30 hover:shadow-blue-600/50 transition-all hover:-translate-y-1 min-w-[160px]"
                                >
                                    <Download className="w-8 h-8 group-hover:animate-bounce" />
                                    <div class="text-center">
                                        <span class="block font-bold text-sm">Descargar PDF</span>
                                        <span class="block text-blue-200 text-xs mt-0.5">Documento oficial</span>
                                    </div>
                                </a>
                            ) : (
                                <div class="flex-shrink-0 flex flex-col items-center justify-center gap-3 px-8 py-6 bg-slate-100 text-slate-400 rounded-2xl border-2 border-dashed border-slate-200 min-w-[160px]">
                                    <FileText className="w-8 h-8" />
                                    <div class="text-center">
                                        <span class="block font-bold text-sm">PDF no disponible</span>
                                        <span class="block text-slate-400 text-xs mt-0.5">Próximamente</span>
                                    </div>
                                </div>
                            )}
                        </div>
                    </div>

                    {/* DATOS CLAVE */}
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">

                        <div class="glass-card rounded-2xl p-6 shadow-sm flex items-center gap-4">
                            <div class="p-3 bg-blue-50 rounded-xl text-blue-600 shrink-0">
                                <CalendarDays className="w-6 h-6" />
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-0.5">Vigencia</p>
                                <p class="font-bold text-slate-800 text-lg leading-tight">{malla.vigencia || '—'}</p>
                            </div>
                        </div>

                        <div class="glass-card rounded-2xl p-6 shadow-sm flex items-center gap-4">
                            <div class="p-3 bg-emerald-50 rounded-xl text-emerald-600 shrink-0">
                                <BookOpen className="w-6 h-6" />
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-0.5">Total de Créditos</p>
                                <p class="font-bold text-slate-800 text-lg leading-tight">{malla.totalCreditos || '—'}</p>
                            </div>
                        </div>

                        <div class="glass-card rounded-2xl p-6 shadow-sm flex items-center gap-4">
                            <div class="p-3 bg-amber-50 rounded-xl text-amber-600 shrink-0">
                                <Award className="w-6 h-6" />
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-0.5">Resolución</p>
                                <p class="font-bold text-slate-800 text-sm leading-tight">{malla.resolucion || '—'}</p>
                            </div>
                        </div>

                    </div>

                    {/* NOTAS ADICIONALES */}
                    {malla.notas && (
                        <div class="glass-card rounded-2xl p-6 shadow-sm flex gap-4 items-start">
                            <div class="p-2.5 bg-slate-100 rounded-xl text-slate-500 shrink-0 mt-0.5">
                                <Info className="w-5 h-5" />
                            </div>
                            <div>
                                <p class="font-bold text-slate-700 mb-1 text-sm uppercase tracking-wider">Notas</p>
                                <p class="text-slate-600 leading-relaxed whitespace-pre-line">{malla.notas}</p>
                            </div>
                        </div>
                    )}

                    {/* AVISO SI NO HAY PDF */}
                    {!malla.archivoPdf && (
                        <div class="mt-6 bg-amber-50 border border-amber-200 rounded-2xl p-5 flex gap-3 items-center">
                            <Info className="w-5 h-5 text-amber-600 shrink-0" />
                            <p class="text-amber-800 text-sm font-medium">
                                El documento PDF aún no ha sido cargado. El administrador puede actualizarlo desde el panel de Keystatic.
                            </p>
                        </div>
                    )}
                </>
            ) : (
                <div class="glass-card rounded-[2.5rem] p-16 text-center shadow-xl">
                    <FileText className="w-16 h-16 text-slate-300 mx-auto mb-6" />
                    <h2 class="text-2xl font-bold text-slate-700 mb-2">Malla curricular no configurada</h2>
                    <p class="text-slate-500">Accede al panel de administración para cargar la información.</p>
                </div>
            )}

        </div>
    </section>

</Layout>
