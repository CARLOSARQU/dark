---
// Archivo: src/pages/docentes/index.astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import {
  Users,
  Briefcase,
  ArrowRight,
  Search,
  Award,
  Sparkles
} from 'lucide-react';

const docentes = await getCollection('docentes');

// Ordenar alfabéticamente
const docentesOrdenados = docentes.sort((a, b) =>
    a.data.nombre.localeCompare(b.data.nombre)
);
---

<Layout title="Plana Docente | EP Ingeniería de Sistemas">

  <style>
    /* Efecto Cristal */
    .glass-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border: 1px solid rgba(255, 255, 255, 0.8);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    }

    /* Gradiente animado para borde de foto */
    .gradient-ring {
      background: linear-gradient(45deg, #3b82f6, #06b6d4, #8b5cf6);
      background-size: 200% 200%;
      animation: gradient-spin 4s ease infinite;
    }

    @keyframes gradient-spin {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    @keyframes float {
      0% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
      100% { transform: translateY(0px); }
    }
    .animate-float { animation: float 6s ease-in-out infinite; }
  </style>

  <section class="relative bg-slate-50 pt-32 pb-16 overflow-hidden">

    <div class="absolute top-[-10%] left-[-5%] w-[600px] h-[600px] bg-blue-100/50 rounded-full blur-[100px] animate-float"></div>
    <div class="absolute bottom-[10%] right-[-5%] w-[500px] h-[500px] bg-indigo-100/40 rounded-full blur-[80px]" style="animation-delay: 2s;"></div>

    <div class="relative z-10 container mx-auto px-6 text-center max-w-4xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur border border-white/60 text-slate-500 text-xs font-bold uppercase tracking-wider mb-8 shadow-sm">
        <Users className="w-4 h-4 text-blue-500" /> Directorio Académico
      </div>

      <h1 class="text-5xl md:text-6xl font-bold text-slate-900 font-title mb-6 tracking-tight">
        Nuestros <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-500">Mentores</span>
      </h1>

      <p class="text-slate-600 text-xl leading-relaxed font-light max-w-2xl mx-auto mb-10">
        Profesionales de alto nivel dedicados a formar la próxima generación de líderes en ingeniería y tecnología.
      </p>

      <div class="max-w-md mx-auto relative group">
        <div class="absolute inset-0 bg-blue-200 rounded-full blur-lg opacity-20 group-hover:opacity-40 transition duration-500"></div>
        <div class="relative flex items-center bg-white rounded-full px-5 py-3 shadow-lg shadow-blue-900/5 border border-slate-100 transition-transform group-hover:scale-[1.02]">
          <Search className="w-5 h-5 text-slate-400 mr-3" />
          <input
              type="text"
              placeholder="Buscar docente por nombre..."
              class="w-full bg-transparent outline-none text-slate-700 placeholder:text-slate-400 font-medium"
              disabled
          />
          <div class="w-px h-6 bg-slate-200 mx-3"></div>
          <span class="text-xs font-bold text-blue-600 cursor-pointer hover:underline">Filtrar</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6 bg-slate-50 min-h-screen relative z-10">
    <div class="container mx-auto max-w-7xl">

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        {docentesOrdenados.map((docente) => (
            <a href={`/docentes/${docente.id}`} class="glass-card group relative rounded-[2rem] p-6 flex flex-col items-center text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(59,130,246,0.15)]">

              <div class="absolute top-4 right-4 z-20">
                <span class="inline-flex items-center justify-center h-8 px-3 bg-white shadow-sm border border-slate-100 rounded-full text-[10px] font-extrabold uppercase tracking-wide text-slate-600 group-hover:text-blue-600 group-hover:border-blue-100 transition-colors">
                    {docente.data.grado}
                </span>
              </div>

              <div class="relative w-32 h-32 mb-6 mt-2">
                <div class="absolute inset-0 rounded-full gradient-ring opacity-0 group-hover:opacity-100 transition duration-500 blur-sm"></div>
                <div class="relative w-full h-full rounded-full p-[3px] bg-white shadow-lg group-hover:scale-105 transition duration-500 overflow-hidden">
                  {docente.data.foto ? (
                      <img
                          src={docente.data.foto}
                          alt={docente.data.nombre}
                          class="w-full h-full object-cover rounded-full grayscale group-hover:grayscale-0 transition duration-500"
                      />
                  ) : (
                      <div class="w-full h-full bg-slate-50 flex items-center justify-center text-slate-300 rounded-full">
                        <Users className="w-12 h-12" />
                      </div>
                  )}
                </div>
              </div>

              <div class="flex-grow flex flex-col items-center w-full">
                <h3 class="text-lg font-bold text-slate-800 mb-2 leading-tight group-hover:text-blue-600 transition-colors">
                  {docente.data.nombre}
                </h3>

                <div class="w-full border-t border-slate-100 my-3 group-hover:border-blue-100 transition-colors"></div>

                <div class="flex items-center gap-2 text-slate-500 text-xs font-medium bg-slate-100/50 px-3 py-1.5 rounded-lg w-full justify-center group-hover:bg-blue-50 group-hover:text-blue-700 transition-colors">
                  <Briefcase className="w-3 h-3" />
                  <span class="truncate">{docente.data.cargo}</span>
                </div>
              </div>

              <div class="mt-6 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                <span class="text-sm font-bold text-slate-900 flex items-center gap-2">
                    Ver perfil completo <ArrowRight className="w-4 h-4 text-blue-500" />
                </span>
              </div>

            </a>
        ))}
      </div>

    </div>
  </section>
</Layout>